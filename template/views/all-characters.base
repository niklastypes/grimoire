filters:
  and:
    - 'file.folder != "templates"'
    - 'type == "character"'

properties:
  character-type:
    displayName: Type
  status:
    displayName: Status
  faction:
    displayName: Faction
  alive:
    displayName: Alive
  canon:
    displayName: Canon

views:
  - type: table
    name: All Characters
