filters:
  and:
    - 'file.folder != "templates"'
    - 'type == "character"'

properties:
  portrait:
    displayName: Portrait
  character-type:
    displayName: Type
  status:
    displayName: Status
  faction:
    displayName: Faction
  alive:
    displayName: Alive
  canon:
    displayName: Canon

views:
  - type: cards
    name: Gallery
    order:
      - portrait
      - file.name
      - character-type
      - status
  - type: table
    name: All Characters
