filters:
  and:
    - 'file.folder != "templates"'
    - 'type == "faction"'

properties:
  portrait:
    displayName: Portrait
  status:
    displayName: Status
  alignment:
    displayName: Alignment
  leader:
    displayName: Leader
  canon:
    displayName: Canon

views:
  - type: cards
    name: Gallery
    order:
      - portrait
      - file.name
      - alignment
      - status
  - type: table
    name: All Factions
