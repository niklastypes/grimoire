filters:
  and:
    - 'file.folder != "templates"'
    - 'type == "lore"'

properties:
  portrait:
    displayName: Portrait
  status:
    displayName: Status
  category:
    displayName: Category
  canon:
    displayName: Canon

views:
  - type: cards
    name: Gallery
    order:
      - portrait
      - file.name
      - category
      - status
  - type: table
    name: All Lore
