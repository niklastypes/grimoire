filters:
  and:
    - 'file.folder != "templates"'
    - 'type == "item"'

properties:
  portrait:
    displayName: Portrait
  status:
    displayName: Status
  held-by:
    displayName: Held By
  canon:
    displayName: Canon

views:
  - type: cards
    name: Gallery
    order:
      - portrait
      - file.name
      - held-by
      - status
  - type: table
    name: All Items
