filters:
  and:
    - 'file.folder != "templates"'
    - 'type == "location"'

properties:
  portrait:
    displayName: Portrait
  status:
    displayName: Status
  district:
    displayName: District
  parent-location:
    displayName: Parent
  canon:
    displayName: Canon

views:
  - type: cards
    name: Gallery
    order:
      - portrait
      - file.name
      - district
      - status
  - type: table
    name: All Locations
